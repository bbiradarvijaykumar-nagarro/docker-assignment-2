{
  "title": "Docker Assignment 2 - App Logs",
  "uid": "docker-assignment-2-logs",
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "time": { "from": "now-1h", "to": "now" },
  "refresh": "10s",
  "panels": [
    {
      "id": 1,
      "type": "logs",
      "title": "App container logs (live tail via Loki)",
      "gridPos": { "h": 14, "w": 24, "x": 0, "y": 0 },
      "datasource": { "type": "loki", "uid": "Loki" },
      "targets": [
        {
          "expr": "{compose_service=\"app\"}",
          "refId": "A"
        }
      ]
    },
    {
      "id": 2,
      "type": "timeseries",
      "title": "Log lines per minute, by container",
      "gridPos": { "h": 8, "w": 24, "x": 0, "y": 14 },
      "datasource": { "type": "loki", "uid": "Loki" },
      "targets": [
        {
          "expr": "sum by (compose_service) (count_over_time({compose_service=~\".+\"}[1m]))",
          "refId": "A"
        }
      ]
    }
  ]
}
